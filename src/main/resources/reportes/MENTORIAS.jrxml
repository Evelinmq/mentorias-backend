<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="MENTORIAS" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="93c128f2-ff36-4dc8-9d08-48083ff492df">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Mentorias.jrdax"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="p_mentor" class="java.lang.String"/>
	<parameter name="p_materia" class="java.lang.String"/>
	<parameter name="p_fecha_inicio" class="java.lang.String"/>
	<parameter name="p_fecha_fin" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT mentoria.fecha AS FECHA,
	materia.nombre AS MATERIA,
	usuarios.nombre AS MENTOR,
	carrera.nombre AS CARRERA,
	tema.nombre AS TEMA,
	mentoria.hora_inicio AS HORA_INICIO,
	mentoria.hora_fin AS HORA_FIN
FROM mentoria
	INNER JOIN materia ON 
	 mentoria.materia_id = materia.id 
	INNER JOIN materia_carrera ON 
	 materia.id = materia_carrera.materia_id
	LEFT JOIN carrera ON 
	 materia_carrera.carrera_id = carrera.id 
	LEFT JOIN usuarios ON 
	 mentoria.mentor_id = usuarios.id 
	LEFT JOIN tema ON 
	 mentoria.id = tema.mentoria_id 
WHERE 
	 ( usuarios.nombre LIKE CONCAT('%', $P{p_mentor}, '%') OR $P{p_mentor} IS NULL OR $P{p_mentor} = '' ) 
     AND ( materia.nombre LIKE CONCAT('%', $P{p_materia}, '%') OR $P{p_materia} IS NULL OR $P{p_materia} = '' )
	 AND ($P{p_fecha_inicio} IS NULL OR fecha >= $P{p_fecha_inicio})
  AND ($P{p_fecha_fin} IS NULL OR fecha <= $P{p_fecha_fin})]]>
	</queryString>
